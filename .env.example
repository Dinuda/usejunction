# Postgres (UseJunction product DB) — port 5433 avoids conflict with local Postgres
DATABASE_URL=postgresql://usejunction:usejunction@localhost:5433/usejunction

# Admin app (Docker default host port 3011 avoids conflict with other services on 3001)
ADMIN_HOST_PORT=3011
ADMIN_PORT=3001
NEXTAUTH_SECRET=change-me-in-production
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
NEXT_PUBLIC_LANGFUSE_URL=http://localhost:3000

# Ingest secrets
INGEST_SECRET=change-me-ingest-secret

# LiteLLM
LITELLM_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-usejunction-master
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# Optional org spend reconciliation
OPENAI_ADMIN_KEY=
ANTHROPIC_ADMIN_KEY=
