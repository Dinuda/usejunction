  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude 'tests/components/**' --exclude '**/*.integration.test.ts'",
    "test:component": "vitest run tests/components",
    "test:integration": "vitest run tests/*.integration.test.ts tests/analytics-query.test.ts",
    "test:coverage": "vitest run --coverage",
    "e2e:seed": "dotenv -e ../../.env -- tsx e2e/seed.ts",
    "test:e2e": "playwright test",
    "test:all": "pnpm test && pnpm e2e:seed && pnpm test:e2e"
  },
